{
    "version": 2,
    "functions": {
      "api/index.php": {
        "runtime": "vercel-php@0.6.0"
      },
      "api/login.php": {
        "runtime": "vercel-php@0.6.0"
      }
    },
    "routes": [
      {
        "src": "/login",
        "dest": "/api/login.php"
      },
      {
        "src": "/",
        "dest": "/api/index.php"
      },
      {
        "src": "/assets/(.*)",
        "dest": "/public/assets/$1"
      }
    ]
  }