{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@latest"
    },
    "api/login.php": {
      "runtime": "vercel-php@latest"
    }
  },
  "routes": [
    {
      "src": "/login",
      "dest": "/api/login.php"
    },
    {
      "src": "/",
      "dest": "/api/index.php"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    }
  ]
}